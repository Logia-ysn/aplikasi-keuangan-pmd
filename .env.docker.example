# ============================================================================
# Keuangan ERP — Docker Environment Variables
#
# Copy file ini ke .env sebelum menjalankan docker compose:
#   cp .env.docker.example .env
#   nano .env   # edit JWT_SECRET dan password
# ============================================================================

# === PostgreSQL ===
POSTGRES_USER=keuangan
POSTGRES_PASSWORD=keuangan_secret_2026
POSTGRES_DB=keuangan_db

# === Aplikasi ===
PORT=3001

# JWT Secret — WAJIB diganti untuk production!
# Generate: openssl rand -hex 48
JWT_SECRET=ganti-dengan-secret-yang-aman

# CORS — domain yang diizinkan mengakses API (pisah dengan koma)
# Contoh: http://localhost:3001,https://keuangan.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3001
