# === Keuangan ERP Server - Environment Variables ===
# Copy this file to .env and fill in the values
#
# Untuk Docker: gunakan .env.docker.example di root project sebagai gantinya.

# PostgreSQL connection string
# Untuk Docker: ganti "localhost" dengan "db" (nama service docker-compose)
DATABASE_URL="postgresql://keuangan:password@localhost:5432/keuangan_db?schema=public"

# Server port
PORT=3001

# JWT Secret (generate with: openssl rand -hex 48)
JWT_SECRET="your-secret-key-here"

# CORS allowed origins (comma-separated)
# For production, add your domain:
# Contoh: http://localhost:5173,https://keuangan.yourdomain.com
ALLOWED_ORIGINS="http://localhost:5173"
