generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum RootType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model Account {
  id             String                   @id @default(uuid())
  name           String
  accountNumber  String                   @unique
  accountType    AccountType
  rootType       RootType
  isGroup        Boolean                  @default(false)
  isActive       Boolean                  @default(true)
  balance        Decimal                  @default(0) @db.Decimal(15, 2)
  currency       String                   @default("IDR")
  description    String?
  parentId       String?
  parent         Account?                 @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]                @relation("AccountHierarchy")
  ledgerEntries  AccountingLedgerEntry[]
  journalItems   JournalItem[]
  salesItems     SalesInvoiceItem[]
  purchaseItems  PurchaseInvoiceItem[]
  payments            Payment[]                @relation("PaymentAccount")
  inventoryItems      InventoryItem[]          @relation("ItemAccount")
  movementsAsOffset   StockMovement[]          @relation("MovementOffset")
  reconciliations     BankReconciliation[]     @relation("ReconciliationAccount")
  serviceItems        ServiceItem[]            @relation("ServiceItemAccount")
  systemAccountMappings SystemAccountMapping[] @relation("MappedAccount")
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([rootType])
  @@index([accountNumber])
  @@index([parentId])
  @@map("accounts")
}

model Party {
  id                String            @id @default(uuid())
  name              String
  partyType         PartyType
  phone             String?
  email             String?
  address           String?
  taxId             String?           @map("tax_id")
  outstandingAmount Decimal           @default(0) @db.Decimal(15, 2) @map("outstanding_amount")
  depositBalance    Decimal           @default(0) @db.Decimal(15, 2) @map("deposit_balance")
  customerDepositBalance Decimal      @default(0) @db.Decimal(15, 2) @map("customer_deposit_balance")
  isActive          Boolean           @default(true) @map("is_active")
  isDummy           Boolean           @default(false) @map("is_dummy")
  salesInvoices     SalesInvoice[]
  purchaseInvoices  PurchaseInvoice[]
  payments          Payment[]
  ledgerEntries     AccountingLedgerEntry[]
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([partyType])
  @@map("parties")
}

enum PartyType {
  Customer
  Supplier
  Both
}

model AccountingLedgerEntry {
  id            String      @id @default(uuid())
  date          DateTime
  accountId     String      @map("account_id")
  account       Account     @relation(fields: [accountId], references: [id])
  partyId       String?     @map("party_id")
  party         Party?      @relation(fields: [partyId], references: [id])
  debit         Decimal     @default(0) @db.Decimal(15, 2)
  credit        Decimal     @default(0) @db.Decimal(15, 2)
  referenceType String      @map("reference_type")
  referenceId   String      @map("reference_id")
  description   String?
  fiscalYearId  String      @map("fiscal_year_id")
  fiscalYear    FiscalYear  @relation(fields: [fiscalYearId], references: [id])
  isCancelled   Boolean     @default(false) @map("is_cancelled")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([accountId])
  @@index([date])
  @@index([fiscalYearId])
  @@index([referenceId])
  @@index([partyId])
  @@map("accounting_ledger_entries")
}

model JournalEntry {
  id           String           @id @default(uuid())
  entryNumber  String           @unique @map("entry_number")
  date         DateTime
  status       DocumentStatus   @default(Draft)
  narration    String?
  fiscalYearId String           @map("fiscal_year_id")
  fiscalYear   FiscalYear       @relation(fields: [fiscalYearId], references: [id])
  createdBy    String           @map("created_by")
  user         User             @relation(fields: [createdBy], references: [id])
  items                JournalItem[]
  stockMovement        StockMovement?
  payment              Payment?
  depositApplication   VendorDepositApplication?
  customerDepositApplication CustomerDepositApplication?
  submittedAt   DateTime?        @map("submitted_at")
  cancelledAt   DateTime?        @map("cancelled_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([date])
  @@index([fiscalYearId])
  @@map("journal_entries")
}

model JournalItem {
  id             String       @id @default(uuid())
  journalEntryId String       @map("journal_entry_id")
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String       @map("account_id")
  account        Account      @relation(fields: [accountId], references: [id])
  partyId        String?      @map("party_id")
  debit          Decimal      @default(0) @db.Decimal(15, 2)
  credit         Decimal      @default(0) @db.Decimal(15, 2)
  description    String?

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_accounts")
}

model SalesInvoice {
  id             String             @id @default(uuid())
  invoiceNumber  String             @unique @map("invoice_number")
  date           DateTime
  partyId        String             @map("party_id")
  customer       Party              @relation(fields: [partyId], references: [id])
  status         InvoiceStatus      @default(Draft)
  grandTotal     Decimal            @db.Decimal(15, 2) @map("grand_total")
  outstanding    Decimal            @db.Decimal(15, 2)
  taxPct         Decimal            @default(0) @db.Decimal(5, 2) @map("tax_pct")
  potongan       Decimal            @default(0) @db.Decimal(15, 2)
  biayaLain      Decimal            @default(0) @db.Decimal(15, 2) @map("biaya_lain")
  labelPotongan  String?            @map("label_potongan")
  labelBiaya     String?            @map("label_biaya")
  terms          String?
  dueDate        DateTime?          @map("due_date")
  notes          String?
  fiscalYearId   String             @map("fiscal_year_id")
  fiscalYear     FiscalYear         @relation(fields: [fiscalYearId], references: [id])
  createdBy      String             @map("created_by")
  user           User               @relation(fields: [createdBy], references: [id])
  items          SalesInvoiceItem[]
  depositApplications CustomerDepositApplication[] @relation("CustomerDepositApplied")
  submittedAt    DateTime?          @map("submitted_at")
  cancelledAt    DateTime?          @map("cancelled_at")
  isDummy        Boolean            @default(false) @map("is_dummy")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@index([partyId])
  @@index([status])
  @@index([date])
  @@index([fiscalYearId])
  @@map("sales_invoices")
}

model SalesInvoiceItem {
  id               String         @id @default(uuid())
  salesInvoiceId   String         @map("sales_invoice_id")
  salesInvoice     SalesInvoice   @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  itemType         String         @default("product") @map("item_type")
  inventoryItemId  String?        @map("inventory_item_id")
  inventoryItem    InventoryItem? @relation("SalesInvoiceInventory", fields: [inventoryItemId], references: [id])
  serviceItemId    String?        @map("service_item_id")
  serviceItem      ServiceItem?   @relation("SalesInvoiceService", fields: [serviceItemId], references: [id])
  itemName         String         @map("item_name")
  quantity         Decimal        @db.Decimal(15, 3)
  unit             String
  rate             Decimal        @db.Decimal(15, 2)
  discount         Decimal        @default(0) @db.Decimal(5, 2)
  amount           Decimal        @db.Decimal(15, 2)
  taxPct           Decimal        @default(0) @db.Decimal(5, 2) @map("tax_pct")
  pphPct           Decimal        @default(0) @db.Decimal(5, 2) @map("pph_pct")
  accountId        String         @map("account_id")
  account          Account        @relation(fields: [accountId], references: [id])
  description      String?

  @@index([salesInvoiceId])
  @@index([inventoryItemId])
  @@index([serviceItemId])
  @@map("sales_invoice_items")
}

model PurchaseInvoice {
  id             String                @id @default(uuid())
  invoiceNumber  String                @unique @map("invoice_number")
  date           DateTime
  partyId        String                @map("party_id")
  supplier       Party                 @relation(fields: [partyId], references: [id])
  status         InvoiceStatus         @default(Draft)
  grandTotal     Decimal               @db.Decimal(15, 2) @map("grand_total")
  outstanding    Decimal               @db.Decimal(15, 2)
  taxPct         Decimal               @default(0) @db.Decimal(5, 2) @map("tax_pct")
  potongan       Decimal               @default(0) @db.Decimal(15, 2)
  biayaLain      Decimal               @default(0) @db.Decimal(15, 2) @map("biaya_lain")
  dueDate        DateTime?             @map("due_date")
  notes          String?
  fiscalYearId   String                @map("fiscal_year_id")
  fiscalYear     FiscalYear            @relation(fields: [fiscalYearId], references: [id])
  createdBy      String                @map("created_by")
  user           User                  @relation(fields: [createdBy], references: [id])
  items               PurchaseInvoiceItem[]
  depositApplications VendorDepositApplication[] @relation("DepositApplied")
  submittedAt    DateTime?             @map("submitted_at")
  cancelledAt    DateTime?             @map("cancelled_at")
  isDummy        Boolean               @default(false) @map("is_dummy")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  @@index([partyId])
  @@index([status])
  @@index([date])
  @@index([fiscalYearId])
  @@map("purchase_invoices")
}

model PurchaseInvoiceItem {
  id                String          @id @default(uuid())
  purchaseInvoiceId String          @map("purchase_invoice_id")
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  inventoryItemId   String?         @map("inventory_item_id")
  inventoryItem     InventoryItem?  @relation("PurchaseInvoiceInventory", fields: [inventoryItemId], references: [id])
  itemName          String          @map("item_name")
  quantity          Decimal         @db.Decimal(15, 3)
  unit              String
  rate              Decimal         @db.Decimal(15, 2)
  discount          Decimal         @default(0) @db.Decimal(5, 2)
  amount            Decimal         @db.Decimal(15, 2)
  taxPct            Decimal         @default(0) @db.Decimal(5, 2) @map("tax_pct")
  accountId         String          @map("account_id")
  account           Account         @relation(fields: [accountId], references: [id])
  description       String?

  @@index([purchaseInvoiceId])
  @@index([inventoryItemId])
  @@map("purchase_invoice_items")
}

model Payment {
  id            String              @id @default(uuid())
  paymentNumber String              @unique @map("payment_number")
  date          DateTime
  paymentType   PaymentType         @map("payment_type")
  partyId       String              @map("party_id")
  party         Party               @relation(fields: [partyId], references: [id])
  accountId     String              @map("account_id")
  account       Account             @relation("PaymentAccount", fields: [accountId], references: [id])
  amount        Decimal             @db.Decimal(15, 2)
  status        DocumentStatus      @default(Draft)
  referenceNo   String?             @map("reference_number")
  notes         String?
  createdBy     String              @map("created_by")
  user          User                @relation(fields: [createdBy], references: [id])
  allocations           PaymentAllocation[]
  depositApplications   VendorDepositApplication[] @relation("DepositApplications")
  customerDepositApplications CustomerDepositApplication[] @relation("CustomerDepositApplications")
  journalEntryId        String?             @unique @map("journal_entry_id")
  journalEntry          JournalEntry?       @relation(fields: [journalEntryId], references: [id])
  fiscalYearId     String              @map("fiscal_year_id")
  fiscalYear    FiscalYear          @relation(fields: [fiscalYearId], references: [id])
  submittedAt   DateTime?           @map("submitted_at")
  cancelledAt   DateTime?           @map("cancelled_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([partyId])
  @@index([accountId])
  @@index([status])
  @@index([date])
  @@index([fiscalYearId])
  @@map("payments")
}

model PaymentAllocation {
  id              String      @id @default(uuid())
  paymentId       String      @map("payment_id")
  payment         Payment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceType     String      @map("invoice_type")
  invoiceId       String      @map("invoice_id")
  allocatedAmount Decimal     @db.Decimal(15, 2) @map("allocated_amount")

  @@index([paymentId])
  @@index([invoiceType, invoiceId])
  @@map("payment_allocations")
}

model FiscalYear {
  id               String                  @id @default(uuid())
  name             String                  @unique
  startDate        DateTime                @map("start_date")
  endDate          DateTime                @map("end_date")
  isClosed         Boolean                 @default(false) @map("is_closed")
  closedAt         DateTime?               @map("closed_at")
  closedBy         String?                 @map("closed_by")
  user             User?                   @relation("ClosedBy", fields: [closedBy], references: [id])
  ledgerEntries    AccountingLedgerEntry[]
  journalEntries   JournalEntry[]
  salesInvoices    SalesInvoice[]
  purchaseInvoices PurchaseInvoice[]
  payments         Payment[]
  stockMovements   StockMovement[]
  productionRuns   ProductionRun[]
  stockOpnames     StockOpname[]
  createdAt        DateTime                @default(now()) @map("created_at")

  @@map("fiscal_years")
}

model User {
  id               String            @id @default(uuid())
  username         String            @unique
  fullName         String            @map("full_name")
  email            String            @unique
  passwordHash     String            @map("password_hash")
  role             UserRole          @default(Accountant)
  isActive         Boolean           @default(true) @map("is_active")
  lastLoginAt      DateTime?         @map("last_login_at")
  journalEntries   JournalEntry[]
  salesInvoices    SalesInvoice[]
  purchaseInvoices PurchaseInvoice[]
  payments         Payment[]
  closedYears      FiscalYear[]      @relation("ClosedBy")
  audits           AuditLog[]
  stockMovements       StockMovement[]       @relation("MovementCreatedBy")
  productionRuns       ProductionRun[]       @relation("ProductionCreatedBy")
  notifications        Notification[]        @relation("UserNotifications")
  recurringTemplates           RecurringTemplate[]          @relation("UserRecurring")
  vendorDepositApplications    VendorDepositApplication[]
  customerDepositApplications  CustomerDepositApplication[]
  tokenBlacklist               TokenBlacklist[]
  attachments                  TransactionAttachment[]
  stockOpnames                 StockOpname[]                @relation("OpnameCreatedBy")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  @@map("users")
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([token])
  @@index([expiresAt])
  @@map("token_blacklist")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_trail")
}

model CompanySettings {
  id                   String  @id @default(uuid())
  slug                 String  @default("default") @unique
  companyName          String  @map("company_name")
  address              String?
  phone                String?
  email                String?
  taxId                String? @map("tax_id")
  logoUrl              String? @map("logo_url")
  defaultCurrency      String  @default("IDR") @map("default_currency")
  fiscalYearStartMonth Int     @default(1) @map("fiscal_year_start_month")

  @@map("company_settings")
}

model SystemAccountMapping {
  id        String   @id @default(uuid())
  role      String
  accountId String   @map("account_id")
  account   Account  @relation("MappedAccount", fields: [accountId], references: [id])
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([role, accountId])
  @@index([role])
  @@map("system_account_mappings")
}

enum DocumentStatus {
  Draft
  Submitted
  Cancelled
}

enum InvoiceStatus {
  Draft
  Submitted
  Paid
  PartiallyPaid
  Overdue
  Cancelled
}

enum PaymentType {
  Receive
  Pay
  VendorDeposit
  CustomerDeposit
}

enum UserRole {
  Admin
  Accountant
  StaffProduksi
  Viewer
}

enum StockMovementType {
  In
  Out
  AdjustmentIn
  AdjustmentOut
}

model InventoryItem {
  id           String          @id @default(uuid())
  code         String          @unique
  name         String
  unit         String
  category     String?
  description  String?
  currentStock Decimal         @default(0) @db.Decimal(15, 3) @map("current_stock")
  averageCost  Decimal         @default(0) @db.Decimal(20, 2) @map("average_cost")
  minimumStock Decimal         @default(0) @db.Decimal(15, 3) @map("minimum_stock")
  isActive     Boolean         @default(true) @map("is_active")
  isDummy      Boolean         @default(false) @map("is_dummy")
  accountId    String?         @map("account_id")
  account      Account?        @relation("ItemAccount", fields: [accountId], references: [id])
  movements             StockMovement[]
  productionLines       ProductionRunItem[]    @relation("ProductionLines")
  salesInvoiceItems     SalesInvoiceItem[]     @relation("SalesInvoiceInventory")
  purchaseInvoiceItems  PurchaseInvoiceItem[]  @relation("PurchaseInvoiceInventory")
  opnameLines           StockOpnameItem[]      @relation("OpnameLines")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@map("inventory_items")
}

model StockMovement {
  id              String            @id @default(uuid())
  movementNumber  String            @unique @map("movement_number")
  date            DateTime
  itemId          String            @map("item_id")
  item            InventoryItem     @relation(fields: [itemId], references: [id])
  movementType    StockMovementType @map("movement_type")
  quantity        Decimal           @db.Decimal(20, 3)
  unitCost        Decimal           @default(0) @db.Decimal(20, 2) @map("unit_cost")
  totalValue      Decimal           @default(0) @db.Decimal(20, 2) @map("total_value")
  notes           String?
  referenceType   String?           @map("reference_type")
  referenceId     String?           @map("reference_id")
  referenceNumber String?           @map("reference_number")
  offsetAccountId String?           @map("offset_account_id")
  offsetAccount   Account?          @relation("MovementOffset", fields: [offsetAccountId], references: [id])
  journalEntryId  String?           @unique @map("journal_entry_id")
  journalEntry    JournalEntry?     @relation(fields: [journalEntryId], references: [id])
  fiscalYearId    String            @map("fiscal_year_id")
  fiscalYear      FiscalYear        @relation(fields: [fiscalYearId], references: [id])
  createdById     String            @map("created_by_id")
  createdBy       User              @relation("MovementCreatedBy", fields: [createdById], references: [id])
  isCancelled     Boolean           @default(false) @map("is_cancelled")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([itemId])
  @@index([date])
  @@index([movementType])
  @@index([fiscalYearId])
  @@map("stock_movements")
}

model ProductionRun {
  id              String              @id @default(uuid())
  runNumber       String              @unique @map("run_number")
  date            DateTime
  notes           String?
  referenceType   String?             @map("reference_type")
  referenceId     String?             @map("reference_id")
  referenceNumber String?             @map("reference_number")
  rendemenPct     Decimal?            @db.Decimal(5, 2) @map("rendemen_pct")
  items           ProductionRunItem[]
  isCancelled     Boolean             @default(false) @map("is_cancelled")
  fiscalYearId    String              @map("fiscal_year_id")
  fiscalYear      FiscalYear          @relation(fields: [fiscalYearId], references: [id])
  createdById     String              @map("created_by_id")
  createdBy       User                @relation("ProductionCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([date])
  @@index([fiscalYearId])
  @@map("production_runs")
}

model ProductionRunItem {
  id              String        @id @default(uuid())
  productionRunId String        @map("production_run_id")
  productionRun   ProductionRun @relation(fields: [productionRunId], references: [id], onDelete: Cascade)
  itemId          String        @map("item_id")
  item            InventoryItem @relation("ProductionLines", fields: [itemId], references: [id])
  lineType        String        @map("line_type")
  quantity        Decimal       @db.Decimal(15, 3)
  unitPrice       Decimal?      @db.Decimal(15, 2) @map("unit_price")
  rendemenPct     Decimal?      @db.Decimal(5, 2) @map("rendemen_pct")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([productionRunId])
  @@map("production_run_items")
}

enum StockOpnameStatus {
  Draft
  Submitted
  Cancelled
}

model StockOpname {
  id           String             @id @default(uuid())
  opnameNumber String             @unique @map("opname_number")
  date         DateTime
  status       StockOpnameStatus  @default(Draft)
  notes        String?
  items        StockOpnameItem[]
  fiscalYearId String             @map("fiscal_year_id")
  fiscalYear   FiscalYear         @relation(fields: [fiscalYearId], references: [id])
  createdById  String             @map("created_by_id")
  createdBy    User               @relation("OpnameCreatedBy", fields: [createdById], references: [id])
  submittedAt  DateTime?          @map("submitted_at")
  cancelledAt  DateTime?          @map("cancelled_at")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([date])
  @@index([status])
  @@index([fiscalYearId])
  @@map("stock_opnames")
}

model StockOpnameItem {
  id            String        @id @default(uuid())
  stockOpnameId String        @map("stock_opname_id")
  stockOpname   StockOpname   @relation(fields: [stockOpnameId], references: [id], onDelete: Cascade)
  itemId        String        @map("item_id")
  item          InventoryItem @relation("OpnameLines", fields: [itemId], references: [id])
  systemStock   Decimal       @db.Decimal(15, 3) @map("system_stock")
  actualStock   Decimal       @db.Decimal(15, 3) @map("actual_stock")
  difference    Decimal       @db.Decimal(15, 3)
  unitCost      Decimal       @default(0) @db.Decimal(20, 2) @map("unit_cost")
  totalValue    Decimal       @default(0) @db.Decimal(20, 2) @map("total_value")
  movementId    String?       @map("movement_id")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([stockOpnameId])
  @@index([itemId])
  @@map("stock_opname_items")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation("UserNotifications", fields: [userId], references: [id])
  type      String   // invoice_overdue, payment_received, low_stock, system
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model RecurringTemplate {
  id           String    @id @default(uuid())
  name         String
  templateType String    @map("template_type") // journal, sales_invoice, purchase_invoice
  frequency    String    // daily, weekly, monthly, quarterly, yearly
  dayOfMonth   Int?      @map("day_of_month")
  nextRunDate  DateTime  @map("next_run_date")
  lastRunDate  DateTime? @map("last_run_date")
  isActive     Boolean   @default(true) @map("is_active")
  templateData Json      @map("template_data")
  createdBy    String    @map("created_by")
  user         User      @relation("UserRecurring", fields: [createdBy], references: [id])
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([isActive, nextRunDate])
  @@map("recurring_templates")
}

model BankReconciliation {
  id               String                    @id @default(uuid())
  accountId        String                    @map("account_id")
  account          Account                   @relation("ReconciliationAccount", fields: [accountId], references: [id])
  statementDate    DateTime                  @map("statement_date")
  statementBalance Decimal                   @db.Decimal(15, 2) @map("statement_balance")
  bookBalance      Decimal                   @default(0) @db.Decimal(15, 2) @map("book_balance")
  status           String                    @default("Draft") // Draft, Completed
  notes            String?
  items            BankReconciliationItem[]
  createdBy        String                    @map("created_by")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")

  @@index([accountId, statementDate])
  @@map("bank_reconciliations")
}

model BankReconciliationItem {
  id               String              @id @default(uuid())
  reconciliationId String              @map("reconciliation_id")
  reconciliation   BankReconciliation  @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  ledgerEntryId    String?             @map("ledger_entry_id")
  isMatched        Boolean             @default(false) @map("is_matched")
  statementAmount  Decimal?            @db.Decimal(15, 2) @map("statement_amount")
  statementDesc    String?             @map("statement_desc")
  statementDate    DateTime?           @map("statement_date")
  createdAt        DateTime            @default(now()) @map("created_at")

  @@index([reconciliationId])
  @@map("bank_reconciliation_items")
}

model TaxConfig {
  id        String   @id @default(uuid())
  name      String
  rate      Decimal  @db.Decimal(5, 2)
  type      String   // sales, purchase, withholding
  accountId String?  @map("account_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tax_configs")
}

model VendorDepositApplication {
  id                String          @id @default(uuid())
  depositPaymentId  String          @map("deposit_payment_id")
  depositPayment    Payment         @relation("DepositApplications", fields: [depositPaymentId], references: [id])
  purchaseInvoiceId String          @map("purchase_invoice_id")
  purchaseInvoice   PurchaseInvoice @relation("DepositApplied", fields: [purchaseInvoiceId], references: [id])
  appliedAmount     Decimal         @db.Decimal(15, 2) @map("applied_amount")
  journalEntryId    String?         @unique @map("journal_entry_id")
  journalEntry      JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  isCancelled       Boolean         @default(false) @map("is_cancelled")
  appliedAt         DateTime        @default(now()) @map("applied_at")
  cancelledAt       DateTime?       @map("cancelled_at")
  createdBy         String          @map("created_by")
  user              User            @relation(fields: [createdBy], references: [id])

  @@index([depositPaymentId])
  @@index([purchaseInvoiceId])
  @@map("vendor_deposit_applications")
}

model CustomerDepositApplication {
  id                String        @id @default(uuid())
  depositPaymentId  String        @map("deposit_payment_id")
  depositPayment    Payment       @relation("CustomerDepositApplications", fields: [depositPaymentId], references: [id])
  salesInvoiceId    String        @map("sales_invoice_id")
  salesInvoice      SalesInvoice  @relation("CustomerDepositApplied", fields: [salesInvoiceId], references: [id])
  appliedAmount     Decimal       @db.Decimal(15, 2) @map("applied_amount")
  journalEntryId    String?       @unique @map("journal_entry_id")
  journalEntry      JournalEntry? @relation(fields: [journalEntryId], references: [id])
  isCancelled       Boolean       @default(false) @map("is_cancelled")
  appliedAt         DateTime      @default(now()) @map("applied_at")
  cancelledAt       DateTime?     @map("cancelled_at")
  createdBy         String        @map("created_by")
  user              User          @relation(fields: [createdBy], references: [id])

  @@index([depositPaymentId])
  @@index([salesInvoiceId])
  @@map("customer_deposit_applications")
}

model ServiceItem {
  id                String             @id @default(uuid())
  code              String             @unique
  name              String
  unit              String             @default("Jasa")
  defaultRate       Decimal?           @db.Decimal(15, 2) @map("default_rate")
  accountId         String             @map("account_id")
  account           Account            @relation("ServiceItemAccount", fields: [accountId], references: [id])
  description       String?
  isActive          Boolean            @default(true) @map("is_active")
  isDummy           Boolean            @default(false) @map("is_dummy")
  salesInvoiceItems SalesInvoiceItem[] @relation("SalesInvoiceService")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([accountId])
  @@map("service_items")
}

model TransactionAttachment {
  id            String   @id @default(uuid())
  referenceType String   @map("reference_type")
  referenceId   String   @map("reference_id")
  fileName      String   @map("file_name")
  storedName    String   @map("stored_name")
  mimeType      String   @map("mime_type")
  fileSize      Int      @map("file_size")
  filePath      String   @map("file_path")
  uploadedBy    String   @map("uploaded_by")
  user          User     @relation(fields: [uploadedBy], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([referenceType, referenceId])
  @@index([uploadedBy])
  @@map("transaction_attachments")
}
